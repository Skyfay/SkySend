{
  "name": "skysend",
  "version": "2.9.2",
  "private": true,
  "type": "module",
  "description": "Minimalist, end-to-end encrypted, self-hostable file sharing service",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "pnpm --parallel --filter=!@skysend/instances-worker dev",
    "build": "pnpm --recursive build",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive --filter=@skysend/server --filter=@skysend/web --filter=@skysend/crypto --filter=@skysend/client test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --recursive typecheck",
    "validate": "bash scripts/validate.sh",
    "version:sync": "bash scripts/sync-version.sh --sync-only",
    "version:bump": "bash scripts/sync-version.sh",
    "changelog:next": "bash scripts/sync-version.sh --changelog-init",
    "client:build": "pnpm --filter @skysend/crypto build && pnpm --filter @skysend/client build",
    "client:run": "tsx apps/client/src/index.ts",
    "client:compile": "pnpm client:build && pnpm --filter @skysend/client build:compile",
    "update:check": "pnpm outdated --recursive 2>&1"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "fast-xml-parser": ">=5.7.2",
      "postcss": ">=8.5.10",
      "@esbuild-kit/core-utils>esbuild": ">=0.25.0",
      "vitepress>vite": "~6.4.2"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
