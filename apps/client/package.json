{
  "name": "@skysend/client",
  "version": "2.4.0",
  "private": true,
  "type": "module",
  "bin": {
    "skysend": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:compile": "bun build --compile --minify src/index.ts --outfile dist/skysend",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 src/index.ts --outfile dist/skysend-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 src/index.ts --outfile dist/skysend-linux-arm64",
    "build:darwin-x64": "bun build --compile --minify --target=bun-darwin-x64 src/index.ts --outfile dist/skysend-darwin-x64",
    "build:darwin-arm64": "bun build --compile --minify --target=bun-darwin-arm64 src/index.ts --outfile dist/skysend-darwin-arm64",
    "build:windows-x64": "bun build --compile --minify --target=bun-windows-x64 src/index.ts --outfile dist/skysend-windows-x64.exe",
    "build:all": "pnpm build:linux-x64 && pnpm build:linux-arm64 && pnpm build:darwin-x64 && pnpm build:darwin-arm64 && pnpm build:windows-x64",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@skysend/crypto": "workspace:*",
    "commander": "^13.1.0",
    "fflate": "^0.8.2",
    "hash-wasm": "^4.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
