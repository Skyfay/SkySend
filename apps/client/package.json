{
  "name": "@skysend/client",
  "version": "2.5.1",
  "private": true,
  "type": "module",
  "bin": {
    "skysend": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:compile": "bun build --compile --minify src/index.ts --outfile dist/skysend",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 src/index.ts --outfile dist/skysend-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 src/index.ts --outfile dist/skysend-linux-arm64",
    "build:macos-x64": "bun build --compile --minify --target=bun-darwin-x64 src/index.ts --outfile dist/skysend-macos-x64",
    "build:macos-arm64": "bun build --compile --minify --target=bun-darwin-arm64 src/index.ts --outfile dist/skysend-macos-arm64",
    "build:windows-x64": "bun build --compile --minify --target=bun-windows-x64 src/index.ts --outfile dist/skysend-windows-x64.exe",
    "build:all": "pnpm build:linux-x64 && pnpm build:linux-arm64 && pnpm build:macos-x64 && pnpm build:macos-arm64 && pnpm build:windows-x64",
    "dev": "tsc --watch",
    "run": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text --passWithNoTests"
  },
  "dependencies": {
    "@skysend/crypto": "workspace:*",
    "commander": "^13.1.0",
    "fflate": "^0.8.2",
    "hash-wasm": "^4.12.0",
    "ink": "^7.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "react-devtools-core": "file:./stubs/react-devtools-core",
    "tsx": "^4.21.0"
  }
}
