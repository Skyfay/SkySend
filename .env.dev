# SkySend Dev Environment (please do not commit changes to this file)

# Network
BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_MAX=600
#FILE_UPLOAD_CONCURRENT_CHUNKS=6
#FILE_UPLOAD_SPEED_LIMIT=100MB
#FILE_UPLOAD_WS=true

# File upload limits
FILE_MAX_SIZE=10GB
FILE_MAX_FILES_PER_UPLOAD=32
FILE_EXPIRE_OPTIONS_SEC=300,3600,3434
FILE_DEFAULT_EXPIRE_SEC=3600
FILE_DOWNLOAD_OPTIONS=10,50,1000
FILE_DEFAULT_DOWNLOAD=50
FILE_UPLOAD_QUOTA_BYTES=100GB

# Note upload limits
NOTE_MAX_SIZE=100KB
NOTE_EXPIRE_OPTIONS_SEC=300,3600,360000
NOTE_DEFAULT_EXPIRE_SEC=3600
NOTE_VIEW_OPTIONS=0,1,100,10000
NOTE_DEFAULT_VIEWS=100

# Password protection
#FORCE_FILE_PASSWORD=false
#FORCE_NOTE_PASSWORD=false
#FORCE_FILE_PASSWORD=true
#FORCE_NOTE_PASSWORD=true

# Appearance
#DEFAULT_THEME=light
#DEFAULT_TAB=password
#ENABLED_SERVICES=file,note
#CUSTOM_TITLE=SkySend Dev
#CUSTOM_COLOR=d63c4a
#CUSTOM_LOGO=

# Footer / Links
CUSTOM_PRIVACY=https://skysend.app
CUSTOM_LEGAL=https://skysend.app
CUSTOM_LINK_URL=https://skysend.app
CUSTOM_LINK_NAME=SkySend

# S3 Storage
#STORAGE_BACKEND=s3
#S3_BUCKET=
#S3_REGION=
#S3_ENDPOINT=
#S3_ACCESS_KEY=
#S3_SECRET_KEY=

# OIDC/SSO Authentication (uncomment to enable)
#------------------------------------------------------------------------------
#OIDC_PROVIDER=pocketid
#OIDC_ISSUER="https://auth.example.com"
#OIDC_CLIENT_ID="your-client-id"
#OIDC_CLIENT_SECRET="your-client-secret"
#OIDC_SESSION_SECRET="" # Generate by: openssl rand -base64 48
#OIDC_PROTECT_FILES=true
#OIDC_PROTECT_NOTES=true