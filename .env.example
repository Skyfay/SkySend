# SkySend Configuration
# Copy this file to .env and adjust values as needed.
# All values shown are defaults.

# ─── Server ────────────────────────────────────────────

# Port the server listens on
PORT=3000

# Host to bind to (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Public URL of this instance (used for generating share links)
BASE_URL=http://localhost:3000

# ─── Storage ───────────────────────────────────────────

# Directory for database files (SQLite DB stored at DATA_DIR/db/skysend.db)
# In Docker, this is mounted as a volume
DATA_DIR=./data

# Directory for encrypted upload files
# Defaults to DATA_DIR/uploads if not set
# In Docker, this is a separate volume at /uploads
# UPLOADS_DIR=./data/uploads

# ─── Limits ────────────────────────────────────────────

# Maximum file size (supports units: KB, MB, GB)
MAX_FILE_SIZE=2GB

# Maximum files per multi-file upload
MAX_FILES_PER_UPLOAD=32

# Comma-separated list of selectable expiry times in seconds
# e.g., 300 (5m), 3600 (1h), 86400 (1d), 604800 (7d)
EXPIRE_OPTIONS_SEC=300,3600,86400,604800

# Default expiry time in seconds
DEFAULT_EXPIRE_SEC=86400

# Comma-separated list of selectable download limits
DOWNLOAD_OPTIONS=1,2,3,4,5,10,20,50,100

# Default download limit
DEFAULT_DOWNLOAD=1

# ─── Cleanup ───────────────────────────────────────────

# Interval in seconds for the cleanup job that removes expired uploads
CLEANUP_INTERVAL=60

# ─── Branding ──────────────────────────────────────────

# Site title shown in the browser tab and UI
SITE_TITLE=SkySend

# ─── Rate Limiting ─────────────────────────────────────

# Time window for rate limiting in milliseconds
RATE_LIMIT_WINDOW=60000

# Maximum requests per rate limit window
RATE_LIMIT_MAX=60

# ─── Upload Quota ──────────────────────────────────────

# Maximum upload volume per user per time window (supports units: KB, MB, GB)
# Uses privacy-preserving hashed IPs (HMAC-SHA256, daily rotating key)
# Set to 0 to disable quota (default)
UPLOAD_QUOTA_BYTES=0

# Quota time window in seconds (default: 86400 = 24h)
UPLOAD_QUOTA_WINDOW=86400

# ─── Reverse Proxy ─────────────────────────────────────

# Trust X-Forwarded-For / X-Real-IP headers (set to true when behind a reverse proxy)
TRUST_PROXY=false

# ─── Docker ─────────────────────────────────────────────

# User ID the container runs as (Docker only)
PUID=1001

# Group ID the container runs as (Docker only)
PGID=1001
