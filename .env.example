# SkySend Configuration
# Copy this file to .env and adjust values as needed.
# Commented-out variables show their default values and are optional.
# Full reference: https://docs.skysend.ch/user-guide/configuration/environment-variables

# ─── Server ────────────────────────────────────────────

# Public URL of this instance (REQUIRED - used for CORS and generated links)
BASE_URL=http://localhost:3000

# Port the server listens on
# PORT=3000

# Host to bind to (0.0.0.0 = all interfaces)
# HOST=0.0.0.0

# Directory for database files (SQLite DB stored at DATA_DIR/db/skysend.db)
# DATA_DIR=./data

# Directory for encrypted upload files (defaults to DATA_DIR/uploads)
# UPLOADS_DIR=./data/uploads

# Trust X-Forwarded-For / X-Real-IP headers (enable when behind a reverse proxy)
# TRUST_PROXY=false

# Additional CORS origins, comma-separated
# CORS_ORIGINS=

# ─── File Limits ───────────────────────────────────────

# Maximum file upload size (supports units: B, KB, MB, GB)
# FILE_MAX_SIZE=2GB

# Maximum number of files per multi-file upload
# FILE_MAX_FILES_PER_UPLOAD=32

# ─── File Expiry ───────────────────────────────────────

# Comma-separated list of selectable expiry times in seconds
# 300=5m, 3600=1h, 86400=1d, 604800=7d
# FILE_EXPIRE_OPTIONS_SEC=300,3600,86400,604800

# Default expiry time in seconds (must be one of FILE_EXPIRE_OPTIONS_SEC)
# FILE_DEFAULT_EXPIRE_SEC=86400

# ─── File Download Limits ──────────────────────────────

# Comma-separated list of selectable download limits
# FILE_DOWNLOAD_OPTIONS=1,2,3,4,5,10,20,50,100

# Default download limit (must be one of FILE_DOWNLOAD_OPTIONS)
# FILE_DEFAULT_DOWNLOAD=1

# ─── File Upload Quota ─────────────────────────────────

# Maximum upload volume per user per window (supports units: B, KB, MB, GB)
# Uses privacy-preserving hashed IPs (HMAC-SHA256, daily rotating key)
# Set to 0 to disable quota (default)
# FILE_UPLOAD_QUOTA_BYTES=0

# Quota time window in seconds (default: 86400 = 24h)
# FILE_UPLOAD_QUOTA_WINDOW=86400

# ─── File Upload Performance ───────────────────────────

# Number of parallel chunk uploads per session (1-20)
# FILE_UPLOAD_CONCURRENT_CHUNKS=3

# Maximum upload speed per session (supports units: B, KB, MB, GB; 0 = unlimited)
# FILE_UPLOAD_SPEED_LIMIT=0

# Enable WebSocket upload transport (improves speed in Chromium browsers)
# Set to false if WebSockets are blocked in your environment
# FILE_UPLOAD_WS=true

# Maximum bytes buffered per WebSocket upload session (min 1MB)
# FILE_UPLOAD_WS_MAX_BUFFER=16MB

# ─── Note Settings ─────────────────────────────────────

# Maximum note content size (supports units: B, KB, MB, GB)
# NOTE_MAX_SIZE=1MB

# Comma-separated list of selectable expiry times for notes in seconds
# NOTE_EXPIRE_OPTIONS_SEC=300,3600,86400,604800

# Default note expiry time in seconds (must be one of NOTE_EXPIRE_OPTIONS_SEC)
# NOTE_DEFAULT_EXPIRE_SEC=86400

# Comma-separated list of selectable view limits (include 0 for unlimited)
# NOTE_VIEW_OPTIONS=1,2,3,5,10,20,50,100

# Default view limit (must be one of NOTE_VIEW_OPTIONS; 1 = burn-after-reading, 0 = unlimited)
# NOTE_DEFAULT_VIEWS=1

# ─── Services ──────────────────────────────────────────

# Enabled services: file, note, or both
# ENABLED_SERVICES=file,note

# ─── Cleanup ───────────────────────────────────────────

# Interval in seconds for the automatic cleanup job
# CLEANUP_INTERVAL=60

# ─── Rate Limiting ─────────────────────────────────────

# Time window for rate limiting in milliseconds
# RATE_LIMIT_WINDOW=60000

# Maximum requests per window per IP
# RATE_LIMIT_MAX=60

# ─── Password Lockout ──────────────────────────────────

# Failed password attempts before an IP is locked out from a specific upload or note
# PASSWORD_MAX_ATTEMPTS=10

# Lockout duration in milliseconds (default: 15 minutes)
# PASSWORD_LOCKOUT_MS=900000

# ─── Storage Backend ───────────────────────────────────

# Storage backend: filesystem (default) or s3
# STORAGE_BACKEND=filesystem

# S3 settings (required when STORAGE_BACKEND=s3)
# S3_BUCKET=skysend-uploads
# S3_REGION=eu-central-1
# S3_ENDPOINT=https://your-s3-endpoint.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_FORCE_PATH_STYLE=false
# S3_PRESIGNED_EXPIRY=300
# S3_PART_SIZE=25MB
# S3_CONCURRENCY=4

# ─── Branding ──────────────────────────────────────────

# Site title shown in the browser tab and UI
# CUSTOM_TITLE=SkySend

# Primary brand color (6-digit hex, # prefix is optional)
# CUSTOM_COLOR=46c89d

# Custom logo URL or absolute path (e.g. https://example.com/logo.svg or /custom-logo.svg)
# CUSTOM_LOGO=https://example.com/logo.svg

# URL to your privacy policy page (shown in footer)
# CUSTOM_PRIVACY=https://example.com/privacy

# URL to your legal notice / impressum page (shown in footer)
# CUSTOM_LEGAL=https://example.com/impressum

# Custom footer link (URL and display name must be set together)
# CUSTOM_LINK_URL=https://example.com
# CUSTOM_LINK_NAME=My Website

# ─── Docker ────────────────────────────────────────────

# User ID and group ID the container runs as
# PUID=1001
# PGID=1001

# Skip chown of /data and /uploads on startup (required for NFS mounts)
# SKIP_CHOWN=false
