# Copy this file to .env.local and adjust for your deployment.

# Public URL this site is served at (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://skysend.app

# Cloudflare Turnstile site key for the /report form.
# Defaults to Cloudflare's "always passes" test key for local development:
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
